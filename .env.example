# Copy to .env, set a long random password, and restrict the file to mode 0600.
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=savapage
POSTGRES_USER=savapage
POSTGRES_VERSION=17.7-bookworm
POSTGRES_MAX_CONNECTIONS=30
SAVAPAGE_DB_POOL_MAX=20

# The published image. `docker compose build` uses the local Dockerfile.
SAVAPAGE_IMAGE=ghcr.io/digikwal/savapage-truenas:1.6.0
SAVAPAGE_VERSION=1.6.0-final
SAVAPAGE_DOWNLOAD_URL=https://www.savapage.org/download/installer/savapage-setup-1.6.0-final-linux-x64.bin
SAVAPAGE_DOWNLOAD_SHA256=b5c388a35b707946ca8f4264605b6b252c6620769e2e32dbf910425fd381433c
JAVA_MAJOR_VERSION=17

TZ=Etc/UTC
LANG=en_US.UTF-8
SAVAPAGE_BIND_IP=127.0.0.1
SAVAPAGE_HTTP_HOST_PORT=8631
SAVAPAGE_HTTPS_HOST_PORT=8632
SAVAPAGE_LOCAL_HTTPS_HOST_PORT=8633
ENABLE_HTTP=true
REDIRECT_HTTP_TO_HTTPS=false

ENABLE_RAW_PRINT=false
SAVAPAGE_RAW_HOST_PORT=9100
ENABLE_CUPS_ADMIN=false
CUPS_ADMIN_HOST_PORT=8634
CUPS_ADMIN_PASSWORD=
CUPS_MAX_JOBS=500
CUPS_PRESERVE_JOB_FILES=No
TRUSTED_LAN_CIDRS=

ENABLE_X_FORWARDED_FOR=false
ALLOWED_PROXY_CIDRS=
SAVAPAGE_ADDITIONAL_PROPERTIES=

SAVAPAGE_CPUS=2.0
SAVAPAGE_MEMORY=4g

# Used only with compose.host-network.yaml.
AIRPRINT_SERVICE_NAME=SavaPage on %h
AIRPRINT_HOSTNAME=savapage.local
AVAHI_ENABLE_IPV4=yes
AVAHI_ENABLE_IPV6=yes

